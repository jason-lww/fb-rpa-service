# ===== HTTP 服务 =====
PORT=8790

# ===== 养号系统网关（incubation）=====
# 真实密钥请勿提交到仓库，使用占位符并在部署环境注入
INCUBATION_GATEWAY_KEY=replace-with-real-gateway-key
# OTP / WaRPA 服务环境：production | test
OTP_SERVICE_ENVIRONMENT=production

# ===== MySQL 留档（Phase2）=====
# 留空则禁用留档（仅内存任务态）。格式：mysql+pymysql://user:pass@host:3306/dbname
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/ics_rpa

# ===== 真实 Chrome（patchright connect_over_cdp）=====
# 先用调试端口启动已登录 FB 的真实 Chrome：
#   chrome --remote-debugging-port=9222 --user-data-dir=/path/to/your/profile
CDP_ENDPOINT=http://127.0.0.1:9222

# ===== FB 自动登录（可选，高风险）=====
# 启动时按账号密码自动登录；遇 2FA/邮箱确认/安全验证会停下并标记“需人工处理”。
# 不配则保持手动登录（更安全，推荐）。
FB_AUTO_LOGIN=false
FB_ACCOUNT=
FB_PASSWORD=

# ===== 绑定节奏（拟人化，降低风控）=====
BETWEEN_PHONE_DELAY_MIN_SECONDS=10
BETWEEN_PHONE_DELAY_MAX_SECONDS=120
ACTION_DELAY_MS=300
